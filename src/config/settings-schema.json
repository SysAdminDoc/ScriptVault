  "metadata": {
    "allowCommunication": {
      "type": "string",
      "control": "select",
      "label": "Allow communication with cooperate pages",
      "help": "Controls allow communication with cooperate pages.",
      "elementId": "settingsAllowCommunication",
      "defaultSource": "runtime",
      "options": [
        {
          "value": "version",
          "label": "ScriptVault + script version"
        },
        {
          "value": "minimal",
          "label": "ScriptVault only"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    "allowCookies": {
      "type": "string",
      "control": "select",
      "label": "Allow scripts to access cookies",
      "help": "Controls allow scripts to access cookies.",
      "elementId": "settingsAllowCookies",
      "defaultSource": "runtime",
      "options": [
        {
          "value": "all",
          "label": "All"
        },
        {
          "value": "matching",
          "label": "Matching only"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    "allowHighPrivilegeScriptApis": {
      "type": "boolean",
      "control": "checkbox",
      "label": "Allow High Privilege Script Apis",
      "help": "Controls allow high privilege script apis.",
      "elementId": "settingsAllowHighPrivilegeScriptApis",
      "default": false
    },
    "allowHttpHeaders": {
      "type": "string",
      "control": "select",
      "label": "Allow HTTP headers to be modified by scripts",
      "help": "Controls allow http headers to be modified by scripts.",
      "elementId": "settingsAllowHttpHeaders",
      "defaultSource": "runtime",
      "options": [
        {
          "value": "yes",
          "label": "Yes"
        },
        {
          "value": "no",
          "label": "No"
        }
      ]
    },
    "allowInternalSyncEndpoints": {
      "type": "boolean",
      "control": "checkbox",
      "label": "Allow Internal Sync Endpoints",
      "help": "Controls allow internal sync endpoints.",
      "elementId": "settingsAllowInternalSyncEndpoints",
      "default": false
    },
    "allowInternalXhr": {
      "type": "boolean",
      "control": "checkbox",
      "label": "Allow Internal XHR",
      "help": "Controls allow internal xhr.",
      "default": false
    },
    "allowLocalFiles": {
      "type": "string",
      "control": "select",
      "label": "Allow scripts to access local files",
      "help": "Controls allow scripts to access local files.",
      "elementId": "settingsAllowLocalFiles",
      "defaultSource": "runtime",
      "options": [
        {
          "value": "all",
          "label": "All local files"
        },
        {
          "value": "ask",
          "label": "Ask"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    "anonymousStats": {
      "type": "boolean",
      "control": "checkbox",
      "label": "Anonymous Stats",
      "help": "Controls anonymous stats.",
      "elementId": "settingsAnonymousStats",
      "defaultSource": "runtime"
    },
    "autoReload": {
      "type": "boolean",
      "control": "checkbox",
      "label": "Auto Reload",
      "help": "Controls auto reload.",
      "elementId": "settingsAutoReload",
      "default": false
