    "blacklistSource": {
      "type": "string",
      "control": "select",
      "label": "Userscript Blacklist Source",
      "help": "Controls userscript blacklist source.",
      "elementId": "settingsBlacklistSource",
      "defaultSource": "runtime",
      "options": [
        {
          "value": "remote_manual",
          "label": "Remote + Manual"
        },
        {
          "value": "remote",
          "label": "Remote only"
        },
        {
          "value": "manual",
          "label": "Manual only"
        },
        {
          "value": "disabled",
          "label": "Disabled"
        }
      ]
    },
    "blacklistedPages": {
      "type": "string",
      "control": "textarea",
      "label": "Blacklisted Pages",
      "help": "Controls blacklisted pages.",
      "elementId": "settingsBlacklistedPages",
      "default": "",
      "validation": {
        "kind": "pattern-line-list",
        "regexLiterals": true,
        "allowGlob": true
      }
    },
    "blockSeverity": {
      "type": "number",
