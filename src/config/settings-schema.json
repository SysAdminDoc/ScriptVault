    "autoSave": {
      "type": "boolean",
      "control": "checkbox",
      "label": "Auto Save",
      "help": "Controls auto save.",
      "elementId": "settingsAutoSave",
      "defaultSource": "runtime"
    },
    "autoUpdate": {
      "type": "boolean",
      "control": "checkbox",
      "label": "Auto Update",
      "help": "Controls auto update.",
      "default": true
    },
