    "badgeColor": {
      "type": "string",
      "control": "text",
      "label": "Icon badge color",
      "help": "Controls icon badge color.",
      "elementId": "settingsBadgeColor",
      "default": "#22c55e",
      "validation": {
        "kind": "hex-color",
        "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
      }
    },
    "badgeInfo": {
      "type": "string",
      "control": "select",
      "label": "Icon badge info",
      "help": "Controls icon badge info.",
      "elementId": "settingsBadgeInfo",
      "default": "running",
      "options": [
        {
          "value": "running",
          "label": "All-time running instances"
        },
        {
          "value": "active",
          "label": "Active scripts only"
        },
        {
          "value": "none",
          "label": "None"
        }
      ]
    },
    "blacklist": {
      "type": "array",
      "control": "textarea",
      "label": "Blacklist",
      "help": "Controls blacklist.",
      "default": []
