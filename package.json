{
  "name": "scriptvault",
  "version": "3.20.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SysAdminDoc/ScriptVault.git"
  },
  "type": "module",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24.16.0",
    "npm": ">=11.13.0"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:bg": "node esbuild.config.mjs --bg-only",
    "build:prod": "node esbuild.config.mjs --prod",
    "build:monaco": "node esbuild.config.mjs --monaco-esm-only",
    "build:firefox": "node scripts/run-bash.mjs build-firefox.sh",
    "firefox:lint": "node scripts/run-bash.mjs build-firefox.sh --lint --keep-build --no-source-zip --prepare-only",
    "firefox:package": "node scripts/run-bash.mjs build-firefox.sh --lint",
    "firefox:warnings": "node scripts/check-firefox-lint-warnings.mjs",
    "firefox:warnings:report": "node scripts/check-firefox-lint-warnings.mjs --report",
    "dev": "node esbuild.config.mjs --watch",
    "dev:tc": "node esbuild.config.mjs --watch --typecheck",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:preview": "node scripts/check-typescript-preview.mjs",
    "typecheck:preview:report": "node scripts/check-typescript-preview.mjs --report",
    "test": "vitest run",
    "test:visual": "vitest run --config vitest.visual.config.mjs",
    "test:e2e": "node scripts/run-e2e.mjs capability",
    "test:e2e:release": "node scripts/run-e2e.mjs release",
    "test:a11y": "node scripts/check-readability.mjs --check && vitest run tests/dashboard-a11y.test.js tests/popup-a11y.test.js tests/gui-ux-audit.test.js tests/accessibility-surface-pass.test.js && node scripts/run-e2e.mjs release tests/e2e/accessibility.spec.js",
    "smoke:dashboard": "node scripts/smoke-dashboard.mjs",
    "smoke:editor": "node scripts/smoke-editor.mjs",
    "smoke:edge": "node scripts/smoke-edge-sideload.mjs",
    "smoke:derivatives": "node scripts/smoke-chromium-derivatives.mjs",
    "smoke:firefox": "node scripts/smoke-firefox-sideload.mjs",
    "smoke:large-library": "node scripts/smoke-large-library.mjs",
    "smoke:large-library:check": "node scripts/smoke-large-library.mjs --check",
    "screenshots": "node scripts/capture-store-screenshots.mjs",
    "cws:check": "node scripts/check-cws-publish-tooling.mjs",
    "cws:remote-code:check": "node scripts/check-cws-remote-code.mjs",
    "ts-source:check": "node scripts/check-ts-source-drift.mjs",
    "ts-source:report": "node scripts/check-ts-source-drift.mjs --report",
    "ts-runtime:generate": "node scripts/generate-ts-runtime-modules.mjs",
    "ts-runtime:check": "node scripts/generate-ts-runtime-modules.mjs --check",
    "gm-types:generate": "node scripts/generate-gm-types.mjs",
    "gm-types:check": "node scripts/generate-gm-types.mjs --check",
    "store-copy:check": "node scripts/check-permission-copy.mjs",
    "toolchain:check": "node scripts/check-toolchain-contract.mjs",
    "local-build-policy:check": "node scripts/check-no-github-actions.mjs",
    "optional-deps:check": "node scripts/check-optional-dep-reach.mjs",
    "settings:schema:check": "node scripts/check-settings-schema.mjs",
    "monaco:package:check": "node scripts/check-monaco-package-contract.mjs",
    "monaco:esm:check": "node scripts/check-monaco-esm-prototype.mjs",
    "host-permissions:prototype": "node scripts/check-host-permission-prototype.mjs --write",
    "host-permissions:prototype:check": "node scripts/check-host-permission-prototype.mjs --check",
    "dashboard:modules:check": "node scripts/check-dashboard-modules.mjs",
    "whatsnew:check": "node scripts/check-whatsnew-changelog.mjs",
    "readability:check": "node scripts/check-readability.mjs --check",
    "readme:check": "node scripts/check-readme-claims.mjs",
    "vendored:provenance": "node scripts/check-vendored-library-provenance.mjs --write",
    "vendored:provenance:check": "node scripts/check-vendored-library-provenance.mjs --check",
    "support:matrix": "npm run build:edge:check && node scripts/generate-browser-support-matrix.mjs",
    "support:matrix:check": "npm run build:edge:check && node scripts/generate-browser-support-matrix.mjs --check",
    "locale:generate": "node scripts/generate-locales.mjs && node scripts/generate-ts-runtime-modules.mjs --module i18n",
    "locale:generate:check": "node scripts/generate-locales.mjs --check && node scripts/generate-ts-runtime-modules.mjs --check --module i18n",
    "locale:check": "node scripts/check-locales.mjs",
    "locale:check:gate": "node scripts/check-locales.mjs --check",
    "locale:check:strict": "node scripts/check-locales.mjs --strict",
    "build:edge": "node scripts/build-edge.mjs",
    "build:edge:check": "node scripts/build-edge.mjs --check",
    "build:edge:stage": "node scripts/build-edge.mjs --no-zip",
    "release:rollback-drill": "vitest run tests/storage-rollback-drill.test.js",
    "release:trust": "node scripts/release-trust-gate.mjs",
    "release:trust:strict": "node scripts/release-trust-gate.mjs --require-signature",
    "release:trust:cra": "node scripts/check-cra-sbom.mjs",
    "release:store-status": "node scripts/check-store-status.mjs",
    "release:check": "node scripts/check-release-artifacts.mjs",
    "release:check:public": "node scripts/check-release-artifacts.mjs --public",
    "release:reproducible-build:check": "node scripts/check-reproducible-build.mjs",
    "release:asset-integrity": "node scripts/check-asset-integrity.mjs",
    "test:cov": "vitest run --coverage && node scripts/check-coverage-sources.mjs",
    "test:cov:report": "vitest run --coverage && node scripts/check-coverage-sources.mjs && echo Coverage report: coverage/index.html",
    "build:analyze": "node scripts/analyze-bundle.mjs",
    "check": "npm run toolchain:check && npm run local-build-policy:check && npm run readme:check && npm run optional-deps:check && npm run settings:schema:check && npm run monaco:package:check && node scripts/check-readability.mjs --check && npm run dashboard:modules:check && npm run whatsnew:check && npm run locale:check:gate && tsc --noEmit && vitest run",
    "clean": "node --input-type=commonjs -e \"const fs=require('fs'); fs.rmSync('background.js',{force:true}); fs.rmSync('lib/monaco',{recursive:true,force:true});\"",
    "publish": "bash publish.sh",
    "publish:draft": "bash publish.sh --draft",
    "cws:setup": "bash cws-setup.sh"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "acorn": "8.17.0",
    "chrome-types": "^0.1.431",
    "chrome-webstore-upload-cli": "4.0.1",
    "diff": "9.0.0",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "monaco-editor": "^0.55.1",
    "puppeteer-core": "^25.2.1",
    "typescript": "7.0.2",
    "typescript-6": "npm:typescript@6.0.3",
    "vitest": "^4.1.9",
    "web-ext": "^10.3.0"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "web-ext": {
      "fx-runner": "1.5.0"
    }
  }
}
