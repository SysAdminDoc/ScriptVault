{
  "name": "scriptvault",
  "version": "2.0.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:bg": "node esbuild.config.mjs --bg-only",
    "build:prod": "node esbuild.config.mjs --prod",
    "build:monaco": "node esbuild.config.mjs --monaco-only",
    "dev": "node esbuild.config.mjs --watch",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "check": "tsc --noEmit && vitest run",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('background.js',{force:true}); fs.rmSync('lib/monaco',{recursive:true,force:true});\""
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chrome-types": "^0.1.425",
    "esbuild": "^0.24.0",
    "jsdom": "^29.0.1",
    "monaco-editor": "^0.52.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
