{
  "name": "scriptvault",
  "version": "3.11.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:bg": "node esbuild.config.mjs --bg-only",
    "build:prod": "node esbuild.config.mjs --prod",
    "build:monaco": "node esbuild.config.mjs --monaco-only",
    "build:firefox": "node scripts/run-bash.mjs build-firefox.sh",
    "firefox:lint": "node scripts/run-bash.mjs build-firefox.sh --lint --keep-build --no-source-zip --prepare-only",
    "firefox:package": "node scripts/run-bash.mjs build-firefox.sh --lint",
    "dev": "node esbuild.config.mjs --watch",
    "watch": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "vitest run tests/dashboard-a11y.test.js tests/popup-a11y.test.js tests/gui-ux-audit.test.js tests/accessibility-surface-pass.test.js",
    "smoke:dashboard": "node scripts/smoke-dashboard.mjs",
    "smoke:firefox": "node scripts/smoke-firefox-sideload.mjs",
    "smoke:large-library": "node scripts/smoke-large-library.mjs",
    "smoke:large-library:check": "node scripts/smoke-large-library.mjs --check",
    "cws:check": "node scripts/check-cws-publish-tooling.mjs",
    "ts-source:check": "node scripts/check-ts-source-drift.mjs",
    "ts-source:report": "node scripts/check-ts-source-drift.mjs --report",
    "ts-runtime:generate": "node scripts/generate-ts-runtime-modules.mjs",
    "ts-runtime:check": "node scripts/generate-ts-runtime-modules.mjs --check",
    "gm-types:generate": "node scripts/generate-gm-types.mjs",
    "gm-types:check": "node scripts/generate-gm-types.mjs --check",
    "store-copy:check": "node scripts/check-permission-copy.mjs",
    "readme:check": "node scripts/check-readme-claims.mjs",
    "support:matrix": "node scripts/generate-browser-support-matrix.mjs",
    "support:matrix:check": "node scripts/generate-browser-support-matrix.mjs --check",
    "locale:check": "node scripts/check-locales.mjs",
    "locale:check:gate": "node scripts/check-locales.mjs --check",
    "locale:check:strict": "node scripts/check-locales.mjs --strict",
    "build:edge": "node scripts/build-edge.mjs",
    "build:edge:check": "node scripts/build-edge.mjs --check",
    "build:edge:stage": "node scripts/build-edge.mjs --no-zip",
    "release:rollback-drill": "vitest run tests/storage-rollback-drill.test.js",
    "release:trust": "node scripts/release-trust-gate.mjs",
    "release:trust:strict": "node scripts/release-trust-gate.mjs --require-signature",
    "release:store-status": "node scripts/check-store-status.mjs",
    "release:check": "node scripts/check-release-artifacts.mjs",
    "release:check:public": "node scripts/check-release-artifacts.mjs --public",
    "test:cov": "vitest run --coverage",
    "check": "tsc --noEmit && vitest run",
    "clean": "node --input-type=commonjs -e \"const fs=require('fs'); fs.rmSync('background.js',{force:true}); fs.rmSync('lib/monaco',{recursive:true,force:true});\"",
    "publish": "bash publish.sh",
    "publish:draft": "bash publish.sh --draft",
    "cws:setup": "bash cws-setup.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.3",
    "chrome-types": "^0.1.425",
    "chrome-webstore-upload-cli": "^4.0.0",
    "esbuild": "^0.27.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "monaco-editor": "^0.52.0",
    "puppeteer-core": "^24.42.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3",
    "web-ext": "^10.3.0"
  }
}
