# ScriptVault Chrome Web Store publishing credentials
# Copy to .env and fill in real values. Never commit .env.
#
# chrome-webstore-upload-cli v4.0.0 (CWS API v2) requires PUBLISHER_ID in
# addition to the OAuth credentials, and reads ALL secrets from env (CLI flags
# for client_id / client_secret / refresh_token were removed in v4).

EXTENSION_ID=your_32_character_chrome_web_store_extension_id
PUBLISHER_ID=your_publisher_id_from_cws_developer_dashboard_settings
CLIENT_ID=your_google_oauth_client_id
CLIENT_SECRET=your_google_oauth_client_secret
REFRESH_TOKEN=your_google_oauth_refresh_token
