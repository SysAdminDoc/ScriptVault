engine-strict=true

# Supply-chain hardening: never run dependency lifecycle scripts (preinstall /
# install / postinstall) during install. This closes the npm-worm lifecycle-
# payload vector (Shai-Hulud / Mini-Shai-Hulud, 2026 H2), where a compromised
# transitive package executes exfiltration/self-propagation code at install
# time. ScriptVault ships zero runtime dependencies, so nothing user-facing
# needs a build step; the only devDependency with a postinstall is esbuild
# (`node install.js`), whose Windows binary is provided by the
# `@esbuild/win32-x64` optional dependency and resolves at runtime without the
# script. If a future devDependency genuinely requires a build step, run it
# explicitly and document it here rather than re-enabling scripts globally.
#
# Publish-token discipline (out-of-band, enforced on the maintainer account):
# the CWS/AMO/npm publish credential is publish-only scope with 2FA/OIDC; it is
# never used for `npm install` and never stored in the repo or CI.
ignore-scripts=true
